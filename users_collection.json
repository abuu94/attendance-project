{
  "info": {
    "name": "FakeStore Users",
    "_postman_id": "12345-abcde-67890",
    "description": "Collection to test FakeStore Users API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Users",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/users"
      }
    },
    {
      "name": "Get Single User",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/users/1"
      }
    },
    {
      "name": "Add New User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"abuuy@example.com\",\n  \"username\": \"abuuy\",\n  \"password\": \"password123\",\n  \"name\": {\"firstname\": \"Abubakar\", \"lastname\": \"Ali\"},\n  \"address\": {\"city\": \"Zanzibar\", \"street\": \"Stone Town\", \"number\": 12, \"zipcode\": \"12345\", \"geolocation\": {\"lat\": \"-26.0\", \"long\": \"28.0\"}},\n  \"phone\": \"+255712345678\"\n}"
        },
        "url": "{{baseUrl}}/users"
      }
    },
    {
      "name": "Update User",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"abuuy_updated@example.com\",\n  \"username\": \"abuuy_updated\",\n  \"password\": \"newpassword123\"\n}"
        },
        "url": "{{baseUrl}}/users/1"
      }
    },
    {
      "name": "Delete User",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/users/1"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://fakestoreapi.com"
    }
  ]
